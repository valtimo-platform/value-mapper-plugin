{
    "compileOnSave": false,
    "compilerOptions": {
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "baseUrl": "./",
        "outDir": "./out-tsc",
        "sourceMap": true,
        "declaration": false,
        "module": "es2020",
        "moduleResolution": "bundler",
        "experimentalDecorators": true,
        "importHelpers": true,
        "esModuleInterop": true,
        "target": "es2022",
        "typeRoots": [
            "node_modules/@types"
        ],
        "lib": [
            "es2021",
            "dom",
            "dom.iterable"
        ],
        "useDefineForClassFields": false,
        "paths": {
            "@src": [
                "src"
            ],
            "@src/*": [
                "src/*"
            ],
            "@valtimo-plugins/value-mapper": [
                "projects/plugin/src/public_api.ts"
            ]
        }
    },
    "include": [
        "***.tsx"
    ],
    "exclude": [
        "node_modules"
    ],
    "files": [],
    "references": [
        {
            "path": "./src/tsconfig.app.json"
        }
    ]
}
