root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

[*.md]
trim_trailing_whitespace = false

[*.{ts,tsx,js,jsx}]
indent_size = 2
max_line_length = 140

[*.{html,htm}]
indent_size = 2

[*.{css,scss,less,sass}]
indent_size = 2

[*.{json,yaml,yml}]
indent_size = 2
